---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>

      <!-- ヒーローセクション -->
      <section class="hero">
        <div class="hero-badge">🐾 ペット栄養アドバイザー ミカ の専門ブログ</div>
        <h1>愛犬・愛猫の食事と健康を<br>正しい知識でサポート</h1>
        <p class="hero-sub">
          ドッグフード・キャットフードの選び方から療法食・栄養管理まで、<br>
          専門的な視点からわかりやすく解説します。
        </p>
        <div class="hero-actions">
          <a href="/blog" class="btn-primary">記事を読む →</a>
          <a href="/about" class="btn-secondary">このブログについて</a>
        </div>
      </section>

      <!-- このブログでわかること -->
      <section class="features">
        <h2 class="section-title">このブログでわかること</h2>
        <div class="feature-grid">
          <div class="feature-card">
            <span class="feature-icon">🍖</span>
            <h3>フードの選び方</h3>
            <p>原材料表示の読み方や成分の見極め方を解説</p>
          </div>
          <div class="feature-card">
            <span class="feature-icon">🏥</span>
            <h3>療法食・病気別食事管理</h3>
            <p>腎臓病・糖尿病・アレルギーなど病気に合わせた食事</p>
          </div>
          <div class="feature-card">
            <span class="feature-icon">⚖️</span>
            <h3>栄養バランス</h3>
            <p>年齢・体型・健康状態に合った栄養管理の方法</p>
          </div>
        </div>
      </section>

      <!-- 最新記事 -->
      <section class="recent-posts">
        <div class="section-header">
          <h2 class="section-title">最新記事</h2>
          <a href="/blog" class="view-all">すべて見る →</a>
        </div>
        <div class="post-grid">
          {posts.map((post) => (
            <a href={`/blog/${post.id}/`} class="post-card">
              {post.data.heroImage && (
                <div class="post-thumb">
                  <img src={post.data.heroImage} alt={post.data.title} />
                </div>
              )}
              <div class="post-body">
                <p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
                <h3>{post.data.title}</h3>
                <p class="post-desc">{post.data.description}</p>
                <span class="post-link">続きを読む →</span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- お問い合わせCTA -->
      <section class="contact-cta">
        <div class="contact-cta-inner">
          <span class="cta-icon">💌</span>
          <h2>ご質問・フードのご相談はお気軽に</h2>
          <p>「うちの子に合うフードは？」「この成分って大丈夫？」など、どんな質問でも歓迎です。</p>
          <a href="/contact" class="btn-primary">お問い合わせ</a>
        </div>
      </section>

    </main>

    <style>
      /* ===== ヒーロー ===== */
      .hero {
        text-align: center;
        padding: 4rem 1.5rem 3.5rem;
        background: linear-gradient(135deg, #f0f9f0 0%, #eaf5fd 100%);
        border-radius: 16px;
        margin: 1.5rem 0 3rem;
      }
      .hero-badge {
        display: inline-block;
        background: rgba(74, 155, 111, 0.12);
        color: #3a7d58;
        font-size: 0.85rem;
        font-weight: 600;
        padding: 0.35rem 1rem;
        border-radius: 999px;
        margin-bottom: 1.2rem;
        letter-spacing: 0.02em;
      }
      .hero h1 {
        font-size: 2rem;
        line-height: 1.45;
        margin: 0 0 1.1rem;
        color: #1a2e1a;
      }
      .hero-sub {
        color: #555;
        line-height: 1.8;
        max-width: 520px;
        margin: 0 auto 2rem;
        font-size: 0.97rem;
      }
      .hero-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
      }

      /* ===== ボタン ===== */
      .btn-primary {
        display: inline-block;
        background: #4a9b6f;
        color: white !important;
        padding: 0.75rem 2rem;
        border-radius: 8px;
        text-decoration: none !important;
        font-weight: bold;
        font-size: 0.95rem;
        transition: background 0.2s, transform 0.1s;
        box-shadow: 0 2px 8px rgba(74, 155, 111, 0.3);
      }
      .btn-primary:hover {
        background: #3a7d58;
        transform: translateY(-1px);
      }
      .btn-secondary {
        display: inline-block;
        background: white;
        color: #4a9b6f !important;
        padding: 0.75rem 2rem;
        border-radius: 8px;
        text-decoration: none !important;
        font-weight: bold;
        font-size: 0.95rem;
        border: 2px solid #4a9b6f;
        transition: background 0.2s, color 0.2s;
      }
      .btn-secondary:hover {
        background: #f0faf4;
      }

      /* ===== セクション共通 ===== */
      .section-title {
        text-align: center;
        font-size: 1.4rem;
        color: #1a2e1a;
        margin-bottom: 1.5rem;
        position: relative;
        padding-bottom: 0.6rem;
      }
      .section-title::after {
        content: '';
        display: block;
        width: 40px;
        height: 3px;
        background: #4a9b6f;
        margin: 0.5rem auto 0;
        border-radius: 999px;
      }

      /* ===== フィーチャーカード ===== */
      .features {
        padding: 1rem 0 3rem;
      }
      .feature-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.2rem;
      }
      .feature-card {
        background: white;
        border: 1px solid #e4ede9;
        border-radius: 12px;
        padding: 1.6rem 1.4rem;
        text-align: center;
        transition: box-shadow 0.2s, transform 0.2s;
      }
      .feature-card:hover {
        box-shadow: 0 4px 16px rgba(74, 155, 111, 0.12);
        transform: translateY(-2px);
      }
      .feature-icon { font-size: 2.2em; }
      .feature-card h3 {
        margin: 0.8rem 0 0.5rem;
        font-size: 1rem;
        color: #1a2e1a;
      }
      .feature-card p {
        color: #666;
        line-height: 1.6;
        margin: 0;
        font-size: 0.9rem;
      }

      /* ===== 最新記事 ===== */
      .recent-posts {
        padding: 1rem 0 3rem;
      }
      .section-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 1.5rem;
      }
      .section-header .section-title {
        margin-bottom: 0;
        text-align: left;
      }
      .section-header .section-title::after {
        margin: 0.5rem 0 0;
      }
      .view-all {
        font-size: 0.88rem;
        color: #4a9b6f;
        text-decoration: none;
        font-weight: 600;
        white-space: nowrap;
      }
      .view-all:hover { text-decoration: underline; }
      .post-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.4rem;
      }
      .post-card {
        background: white;
        border: 1px solid #e4ede9;
        border-radius: 12px;
        overflow: hidden;
        text-decoration: none !important;
        color: inherit;
        transition: box-shadow 0.2s, transform 0.2s;
        display: flex;
        flex-direction: column;
      }
      .post-card:hover {
        box-shadow: 0 6px 20px rgba(74, 155, 111, 0.14);
        transform: translateY(-3px);
      }
      .post-thumb {
        width: 100%;
        aspect-ratio: 16/9;
        overflow: hidden;
        background: #f0f9f0;
      }
      .post-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 0;
        display: block;
      }
      .post-body {
        padding: 1.1rem 1.2rem 1.3rem;
        flex: 1;
        display: flex;
        flex-direction: column;
      }
      .post-date {
        font-size: 0.8rem;
        color: #888;
        margin: 0 0 0.4rem;
      }
      .post-body h3 {
        font-size: 0.97rem;
        color: #1a2e1a;
        margin: 0 0 0.6rem;
        line-height: 1.5;
      }
      .post-desc {
        font-size: 0.85rem;
        color: #666;
        line-height: 1.6;
        margin: 0 0 0.8rem;
        flex: 1;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .post-link {
        font-size: 0.85rem;
        color: #4a9b6f;
        font-weight: 600;
      }

      /* ===== お問い合わせCTA ===== */
      .contact-cta {
        padding: 0 0 2rem;
      }
      .contact-cta-inner {
        background: linear-gradient(135deg, #f0faf4 0%, #eaf5fd 100%);
        border: 1px solid #c8e6d5;
        border-radius: 16px;
        padding: 2.5rem 2rem;
        text-align: center;
      }
      .cta-icon { font-size: 2rem; display: block; margin-bottom: 0.8rem; }
      .contact-cta-inner h2 {
        font-size: 1.25rem;
        color: #1a2e1a;
        margin: 0 0 0.7rem;
      }
      .contact-cta-inner p {
        color: #555;
        margin: 0 0 1.5rem;
        font-size: 0.95rem;
      }

      /* ===== レスポンシブ ===== */
      @media (max-width: 720px) {
        .hero h1 { font-size: 1.5rem; }
        .hero-sub br { display: none; }
        .post-grid { grid-template-columns: 1fr; }
        .section-header { flex-direction: column; gap: 0.5rem; }
      }
    </style>

    <Footer />
  </body>
</html>
