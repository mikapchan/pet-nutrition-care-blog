---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const categories = [
  {
    title: '犬のフード選び',
    desc: '原材料・成分・グレード別に徹底解説',
    img: '/images/dog-food-ingredients-hero.png',
    href: '/blog/dog-food-ingredients-guide/',
  },
  {
    title: '猫のフード選び',
    desc: 'キャットフードの選び方と注意点',
    img: '/images/cat-food-hero.png',
    href: '/blog/cat-food-ingredients-guide/',
  },
  {
    title: 'シニア犬・猫の食事',
    desc: '年齢に合わせた栄養管理とフード選び',
    img: '/images/senior-dog-food-hero.png',
    href: '/blog/dog-senior-food-guide/',
  },
  {
    title: 'アレルギー・療法食',
    desc: '食物アレルギーに対応したフードの見つけ方',
    img: '/images/dog-allergy-hero.png',
    href: '/blog/dog-allergy-food/',
  },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

      <!-- ===== HERO ===== -->
      <section class="hero">
        <div class="hero-overlay"></div>
        <div class="hero-content">
          <p class="hero-eyebrow">🐾 ペット栄養管理士 ミカ の専門ブログ</p>
          <h1>愛犬・愛猫の食事と健康を<br>正しい知識でサポート</h1>
          <p class="hero-sub">
            フード選びの悩みに、専門的な視点からわかりやすく答えます。<br>
            根拠のある情報だけを、正直にお伝えします。
          </p>
          <div class="hero-actions">
            <a href="/blog" class="btn-primary">記事を読む →</a>
            <a href="/about" class="btn-outline">このブログについて</a>
          </div>
        </div>
      </section>

    <main>

      <!-- ===== TRUST BAR ===== -->
      <div class="trust-bar">
        <span>📝 全13記事</span>
        <span class="sep">|</span>
        <span>🐕 犬・🐈 猫どちらも対応</span>
        <span class="sep">|</span>
        <span>📚 AAFCO・NRC基準に基づく解説</span>
        <span class="sep">|</span>
        <span>🔬 参考文献・エビデンス掲載</span>
      </div>

      <!-- ===== カテゴリー ===== -->
      <section class="categories">
        <h2 class="section-title">カテゴリーから探す</h2>
        <div class="category-grid">
          {categories.map((cat) => (
            <a href={cat.href} class="category-card">
              <div class="category-img">
                <img src={cat.img} alt={cat.title} />
                <div class="category-img-overlay"></div>
              </div>
              <div class="category-body">
                <h3>{cat.title}</h3>
                <p>{cat.desc}</p>
                <span class="category-link">詳しく読む →</span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- ===== 最新記事 ===== -->
      <section class="recent-posts">
        <div class="section-header">
          <h2 class="section-title">最新記事</h2>
          <a href="/blog" class="view-all">すべて見る →</a>
        </div>
        <div class="post-grid">
          {posts.map((post) => (
            <a href={`/blog/${post.id}/`} class="post-card">
              {post.data.heroImage && (
                <div class="post-thumb">
                  <img src={post.data.heroImage} alt={post.data.title} />
                </div>
              )}
              <div class="post-body">
                <p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
                <h3>{post.data.title}</h3>
                <p class="post-desc">{post.data.description}</p>
                <span class="post-link">続きを読む →</span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- ===== 著者プロフィール ===== -->
      <section class="author-section">
        <div class="author-card">
          <div class="author-avatar">🐾</div>
          <div class="author-info">
            <p class="author-label">このブログの著者</p>
            <h2 class="author-name">ミカ</h2>
            <p class="author-title">ペット栄養管理士</p>
            <p class="author-bio">
              愛猫のフード選びで何年も迷い、たくさんの失敗をしました。その経験から「ペット栄養管理士」の資格を取得し、食事・栄養・動物の体の仕組み・病気についての正しい知識を体系的に学びました。このブログはその学びを、同じ悩みを持つ方と共有するために立ち上げました。
            </p>
            <a href="/about" class="btn-text">プロフィールを読む →</a>
          </div>
        </div>
      </section>

    </main>

    <style>
      /* ===== HERO ===== */
      .hero {
        position: relative;
        min-height: 520px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background-image: url('/images/hero-dog-cat.png');
        background-size: cover;
        background-position: center center;
      }
      .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          135deg,
          rgba(10, 30, 15, 0.68) 0%,
          rgba(10, 25, 35, 0.55) 100%
        );
      }
      .hero-content {
        position: relative;
        z-index: 1;
        text-align: center;
        padding: 3.5rem 1.5rem;
        max-width: 620px;
      }
      .hero-eyebrow {
        display: inline-block;
        background: rgba(255, 255, 255, 0.15);
        color: rgba(255, 255, 255, 0.92);
        font-size: 0.82rem;
        font-weight: 600;
        padding: 0.3rem 1rem;
        border-radius: 999px;
        margin-bottom: 1.2rem;
        letter-spacing: 0.03em;
        border: 1px solid rgba(255,255,255,0.25);
      }
      .hero-content h1 {
        font-size: 2.1rem;
        line-height: 1.45;
        color: #ffffff;
        margin: 0 0 1rem;
        text-shadow: 0 2px 12px rgba(0,0,0,0.3);
      }
      .hero-sub {
        color: rgba(255, 255, 255, 0.88);
        line-height: 1.85;
        font-size: 0.95rem;
        margin: 0 0 2rem;
      }
      .hero-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
      }
      .btn-primary {
        display: inline-block;
        background: #4a9b6f;
        color: white !important;
        padding: 0.8rem 2rem;
        border-radius: 8px;
        text-decoration: none !important;
        font-weight: bold;
        font-size: 0.95rem;
        transition: background 0.2s, transform 0.1s;
        box-shadow: 0 3px 12px rgba(74, 155, 111, 0.4);
      }
      .btn-primary:hover { background: #3a7d58; transform: translateY(-1px); }
      .btn-outline {
        display: inline-block;
        background: transparent;
        color: white !important;
        padding: 0.8rem 2rem;
        border-radius: 8px;
        text-decoration: none !important;
        font-weight: bold;
        font-size: 0.95rem;
        border: 2px solid rgba(255,255,255,0.7);
        transition: background 0.2s;
      }
      .btn-outline:hover { background: rgba(255,255,255,0.12); }

      /* ===== TRUST BAR ===== */
      .trust-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0.6rem 1rem;
        background: #f0faf4;
        border: 1px solid #c8e6d5;
        border-radius: 10px;
        padding: 0.85rem 1.5rem;
        margin: 1.2rem 0 3rem;
        font-size: 0.82rem;
        color: #3a5a40;
        font-weight: 500;
      }
      .trust-bar .sep { color: #c8e6d5; }

      /* ===== SECTION TITLE ===== */
      .section-title {
        font-size: 1.35rem;
        color: #1a2e1a;
        margin-bottom: 1.5rem;
        position: relative;
        padding-bottom: 0.6rem;
      }
      .section-title::after {
        content: '';
        display: block;
        width: 36px;
        height: 3px;
        background: #4a9b6f;
        margin-top: 0.5rem;
        border-radius: 999px;
      }

      /* ===== CATEGORIES ===== */
      .categories {
        margin-bottom: 3.5rem;
      }
      .category-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.2rem;
      }
      .category-card {
        background: white;
        border-radius: 14px;
        overflow: hidden;
        text-decoration: none !important;
        color: inherit;
        border: 1px solid #e4ede9;
        transition: box-shadow 0.2s, transform 0.2s;
        display: flex;
        flex-direction: column;
      }
      .category-card:hover {
        box-shadow: 0 8px 28px rgba(74, 155, 111, 0.16);
        transform: translateY(-3px);
      }
      .category-img {
        position: relative;
        width: 100%;
        aspect-ratio: 16/9;
        overflow: hidden;
      }
      .category-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 0;
        display: block;
        transition: transform 0.3s;
      }
      .category-card:hover .category-img img {
        transform: scale(1.04);
      }
      .category-img-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(15,40,20,0.3) 0%, transparent 60%);
      }
      .category-body {
        padding: 1.1rem 1.2rem 1.3rem;
        flex: 1;
        display: flex;
        flex-direction: column;
      }
      .category-body h3 {
        font-size: 1rem;
        color: #1a2e1a;
        margin: 0 0 0.4rem;
      }
      .category-body p {
        font-size: 0.85rem;
        color: #666;
        line-height: 1.6;
        margin: 0 0 0.8rem;
        flex: 1;
      }
      .category-link {
        font-size: 0.85rem;
        color: #4a9b6f;
        font-weight: 600;
      }

      /* ===== 最新記事 ===== */
      .recent-posts { margin-bottom: 3.5rem; }
      .section-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 1.5rem;
      }
      .section-header .section-title { margin-bottom: 0; }
      .view-all {
        font-size: 0.88rem;
        color: #4a9b6f;
        text-decoration: none;
        font-weight: 600;
        white-space: nowrap;
      }
      .view-all:hover { text-decoration: underline; }
      .post-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.4rem;
      }
      .post-card {
        background: white;
        border: 1px solid #e4ede9;
        border-radius: 14px;
        overflow: hidden;
        text-decoration: none !important;
        color: inherit;
        transition: box-shadow 0.2s, transform 0.2s;
        display: flex;
        flex-direction: column;
      }
      .post-card:hover {
        box-shadow: 0 6px 22px rgba(74, 155, 111, 0.15);
        transform: translateY(-3px);
      }
      .post-thumb {
        width: 100%;
        aspect-ratio: 16/9;
        overflow: hidden;
        background: #f0f9f0;
      }
      .post-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 0;
        display: block;
        transition: transform 0.3s;
      }
      .post-card:hover .post-thumb img { transform: scale(1.04); }
      .post-body {
        padding: 1.1rem 1.2rem 1.3rem;
        flex: 1;
        display: flex;
        flex-direction: column;
      }
      .post-date {
        font-size: 0.78rem;
        color: #999;
        margin: 0 0 0.4rem;
      }
      .post-body h3 {
        font-size: 0.95rem;
        color: #1a2e1a;
        margin: 0 0 0.6rem;
        line-height: 1.55;
      }
      .post-desc {
        font-size: 0.83rem;
        color: #666;
        line-height: 1.6;
        margin: 0 0 0.8rem;
        flex: 1;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .post-link {
        font-size: 0.83rem;
        color: #4a9b6f;
        font-weight: 600;
      }

      /* ===== 著者プロフィール ===== */
      .author-section { margin-bottom: 3rem; }
      .author-card {
        display: flex;
        gap: 2rem;
        align-items: flex-start;
        background: white;
        border: 1px solid #e4ede9;
        border-radius: 16px;
        padding: 2rem 2.2rem;
        box-shadow: 0 2px 12px rgba(74,155,111,0.07);
      }
      .author-avatar {
        font-size: 3.5rem;
        flex-shrink: 0;
        width: 80px;
        height: 80px;
        background: #f0faf4;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #c8e6d5;
      }
      .author-label {
        font-size: 0.78rem;
        color: #4a9b6f;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin: 0 0 0.2rem;
      }
      .author-name {
        font-size: 1.3rem;
        color: #1a2e1a;
        margin: 0 0 0.1rem;
      }
      .author-title {
        font-size: 0.85rem;
        color: #888;
        margin: 0 0 0.8rem;
      }
      .author-bio {
        font-size: 0.9rem;
        color: #555;
        line-height: 1.75;
        margin: 0 0 1rem;
      }
      .btn-text {
        font-size: 0.88rem;
        color: #4a9b6f;
        font-weight: 600;
        text-decoration: none;
      }
      .btn-text:hover { text-decoration: underline; }

      /* ===== レスポンシブ ===== */
      @media (max-width: 720px) {
        .hero { min-height: 380px; }
        .hero-content h1 { font-size: 1.55rem; }
        .hero-sub br { display: none; }
        .trust-bar { font-size: 0.78rem; gap: 0.4rem 0.8rem; }
        .trust-bar .sep { display: none; }
        .category-grid { grid-template-columns: repeat(2, 1fr); gap: 0.8rem; }
        .post-grid { grid-template-columns: 1fr; }
        .author-card { flex-direction: column; gap: 1.2rem; padding: 1.5rem; }
        .section-header { flex-direction: column; gap: 0.5rem; }
      }
      @media (max-width: 420px) {
        .category-grid { grid-template-columns: 1fr; }
      }
    </style>

    <Footer />
  </body>
</html>
